# Скопируйте в корень проекта: cp deploy/env.example .env
# Перед запуском: source .env

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=замените-на-длинный-случайный-ключ
DJANGO_ALLOWED_HOSTS=green-cafe-str.ru,www.green-cafe-str.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://green-cafe-str.ru,https://www.green-cafe-str.ru

API_CORS_ORIGINS=https://green-cafe-str.ru,https://www.green-cafe-str.ru

# Оставьте пустым на сервере (запросы идут через nginx на тот же домен)
API_BASE_URL=

DJANGO_BIND=127.0.0.1:8135
API_BIND=127.0.0.1:8036
